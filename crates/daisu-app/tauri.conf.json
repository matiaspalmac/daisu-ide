{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Daisu",
  "version": "0.4.1",
  "identifier": "dev.daisu.app",
  "build": {
    "beforeDevCommand": "pnpm --filter @daisu/ui dev",
    "beforeBuildCommand": "pnpm --filter @daisu/ui build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../../apps/ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Daisu IDE",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "additionalBrowserArgs": "--disable-features=msEdgeMouseGestureSupported,msEdgeMouseGestureDefaultEnabled,Translate,AutofillServerCommunication,OptimizationHints,MediaRouter,InterestFeedContentSuggestions,CalculateNativeWinOcclusion --enable-zero-copy --enable-gpu-rasterization"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": ["icons/icon.ico"],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/matiaspalmac/daisu-ide/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU0M0U2QzhDQUM0MzI3NUIKUldSYkowT3NqR3crVkZYbHBhZnFOOEpPbzhMSFJYQnRtSU5FV1lLYzRMa1l1Wm1HK2d2NUFBU3EK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
