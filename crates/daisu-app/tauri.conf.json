{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Daisu",
  "version": "0.4.0",
  "identifier": "dev.daisu.app",
  "build": {
    "beforeDevCommand": "pnpm --filter @daisu/ui dev",
    "beforeBuildCommand": "pnpm --filter @daisu/ui build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../../apps/ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Daisu IDE",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  },
  "plugins": {}
}
