{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Daisu",
  "version": "0.0.1",
  "identifier": "dev.daisu.app",
  "build": {
    "beforeDevCommand": "pnpm --filter @daisu/ui dev",
    "beforeBuildCommand": "pnpm --filter @daisu/ui build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../../apps/ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Daisu IDE",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  },
  "plugins": {
    "dialog": {},
    "fs": {
      "scope": ["$HOME/**", "$DOCUMENT/**", "$DESKTOP/**"]
    }
  }
}
