    { "scope": "keyword.operator", "settings": { "foreground": "#8FA0B8" } },
    { "scope": "storage.modifier", "settings": { "foreground": "#C8A46A" } },
    { "scope": "entity.name.type", "settings": { "foreground": "#B8A8D4", "fontStyle": "italic" } },
    { "scope": "entity.name.class", "settings": { "foreground": "#B8A8D4", "fontStyle": "bold" } },
    { "scope": "entity.name.function", "settings": { "foreground": "#E8C497" } },
    { "scope": "entity.other.attribute-name", "settings": { "foreground": "#DDB87A" } },
    { "scope": "entity.name.tag", "settings": { "foreground": "#C8A46A" } },
    { "scope": "support.type", "settings": { "foreground": "#B8A8D4" } },
    { "scope": "support.class", "settings": { "foreground": "#B8A8D4" } },
    { "scope": "support.function", "settings": { "foreground": "#E8C497" } },
    { "scope": "support.constant", "settings": { "foreground": "#D4A574" } },
    { "scope": "variable", "settings": { "foreground": "#E8E4DA" } },
    { "scope": "variable.parameter", "settings": { "foreground": "#A8A296" } },
    { "scope": "variable.other", "settings": { "foreground": "#E8E4DA" } },
    { "scope": "punctuation", "settings": { "foreground": "#8A8478" } },
    { "scope": "punctuation.definition.tag", "settings": { "foreground": "#C8A46A" } },
    { "scope": "meta.tag", "settings": { "foreground": "#DDB87A" } },
    { "scope": "meta.embedded", "settings": { "foreground": "#E8E4DA" } },
    { "scope": "markup.heading", "settings": { "foreground": "#D4A574", "fontStyle": "bold" } },
    { "scope": "markup.bold", "settings": { "fontStyle": "bold" } },
    { "scope": "markup.italic", "settings": { "fontStyle": "italic" } },
    { "scope": "markup.underline.link", "settings": { "foreground": "#8FA0B8" } },
    { "scope": "invalid", "settings": { "foreground": "#B8736A" } },
    { "scope": "invalid.deprecated", "settings": { "foreground": "#C8A46A" } }
