  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#5A5A66", "fontStyle": "italic" } },
    { "scope": "comment.line", "settings": { "foreground": "#5A5A66", "fontStyle": "italic" } },
    { "scope": "comment.block", "settings": { "foreground": "#5A5A66", "fontStyle": "italic" } },
    { "scope": "string", "settings": { "foreground": "#A8C09A" } },
    { "scope": "string.quoted", "settings": { "foreground": "#A8C09A" } },
    { "scope": "string.regexp", "settings": { "foreground": "#B8D0A8" } },
    { "scope": "constant.character.escape", "settings": { "foreground": "#B8D0A8" } },
    { "scope": "constant.numeric", "settings": { "foreground": "#D4A574" } },
    { "scope": "constant.language", "settings": { "foreground": "#DDB87A" } },
    { "scope": ["keyword", "storage.type"], "settings": { "foreground": "#C8A46A", "fontStyle": "bold" } },
