    "editor.foreground": "#C5D4E3",
    "editor.selectionBackground": "#6FC3DF33",
    "editor.inactiveSelectionBackground": "#6FC3DF1A",
    "editor.lineHighlightBackground": "#0A0E1A",
    "editorCursor.foreground": "#9BDDF5",
    "editorLineNumber.foreground": "#4A5868",
    "editorLineNumber.activeForeground": "#9BDDF5",
    "editorIndentGuide.background": "#1A2632",
    "editorIndentGuide.activeBackground": "#3A8FB5",
    "editorWhitespace.foreground": "#1A2632",
    "editorBracketMatch.background": "#6FC3DF22",
    "editorBracketMatch.border": "#6FC3DF",
    "editorBracketHighlight.foreground1": "#6FC3DF",
    "editorBracketHighlight.foreground2": "#FFA500",
    "editorBracketHighlight.foreground3": "#9BDDF5",
    "editorWidget.background": "#0F1622",
    "editorWidget.border": "#6FC3DF33",
    "editorSuggestWidget.background": "#0F1622",
    "editorSuggestWidget.border": "#6FC3DF33",
    "editorSuggestWidget.selectedBackground": "#6FC3DF1A",
    "minimap.background": "#05080F",
