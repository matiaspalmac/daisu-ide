    "minimapSlider.activeBackground": "#6FC3DF44",
    "editorGutter.background": "#05080F",
    "editorGutter.modifiedBackground": "#FFA500",
    "editorGutter.addedBackground": "#4ADE80",
    "editorGutter.deletedBackground": "#FF6E00",
    "editorOverviewRuler.border": "rgba(111,195,223,0.08)",
    "editorOverviewRuler.modifiedForeground": "#FFA500",
    "editorOverviewRuler.addedForeground": "#4ADE80",
    "editorOverviewRuler.deletedForeground": "#FF6E00",
    "editorOverviewRuler.errorForeground": "#FF6E00",
    "editorOverviewRuler.warningForeground": "#FFA500",
    "editorOverviewRuler.infoForeground": "#6FC3DF",
    "editorStickyScroll.background": "#0A0E1A",
    "editorStickyScrollHover.background": "#0F1622",
    "editorRuler.foreground": "rgba(111,195,223,0.10)",
    "editorError.foreground": "#FF6E00",
    "editorWarning.foreground": "#FFA500",
    "editorInfo.foreground": "#6FC3DF",
    "editorHint.foreground": "#8FA3BD",
    "scrollbar.shadow": "#00000000",
    "scrollbarSlider.background": "#6FC3DF14",
    "scrollbarSlider.hoverBackground": "#6FC3DF22",
    "scrollbarSlider.activeBackground": "#6FC3DF44",
    "sideBar.background": "#0A0E1A",
    "sideBar.foreground": "#C5D4E3",
    "sideBarTitle.foreground": "#8FA3BD",
    "tab.activeBackground": "#05080F",
    "tab.inactiveBackground": "#0A0E1A",
    "tab.activeForeground": "#C5D4E3",
    "tab.inactiveForeground": "#8FA3BD",
    "tab.border": "rgba(111, 195, 223, 0.08)",
    "statusBar.background": "#0A0E1A",
    "statusBar.foreground": "#8FA3BD",
    "titleBar.activeBackground": "#0A0E1A",
    "titleBar.activeForeground": "#C5D4E3",
    "panel.background": "#0A0E1A",
    "panel.border": "rgba(111, 195, 223, 0.08)",
    "input.background": "#0F1622",
    "input.foreground": "#C5D4E3",
    "input.border": "rgba(111, 195, 223, 0.08)",
    "button.background": "#6FC3DF",
    "button.foreground": "#050810"
  },
  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#4A5868", "fontStyle": "italic" } },
    { "scope": "comment.line", "settings": { "foreground": "#4A5868", "fontStyle": "italic" } },
    { "scope": "comment.block", "settings": { "foreground": "#4A5868", "fontStyle": "italic" } },
    { "scope": "string", "settings": { "foreground": "#FFA500" } },
    { "scope": "string.quoted", "settings": { "foreground": "#FFA500" } },
    { "scope": "string.regexp", "settings": { "foreground": "#FFB833" } },
    { "scope": "constant.character.escape", "settings": { "foreground": "#FFB833" } },
    { "scope": "constant.numeric", "settings": { "foreground": "#FF8533" } },
    { "scope": "constant.language", "settings": { "foreground": "#9BDDF5" } },
    { "scope": ["keyword", "storage.type"], "settings": { "foreground": "#6FC3DF", "fontStyle": "bold" } },
    { "scope": "keyword.control", "settings": { "foreground": "#9BDDF5" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#9BDDF5" } },
    { "scope": "storage.modifier", "settings": { "foreground": "#6FC3DF" } },
    { "scope": "entity.name.type", "settings": { "foreground": "#9BDDF5" } },
    { "scope": "entity.name.class", "settings": { "foreground": "#9BDDF5", "fontStyle": "bold" } },
    { "scope": "entity.name.function", "settings": { "foreground": "#C5D4E3", "fontStyle": "bold" } },
    { "scope": "entity.other.attribute-name", "settings": { "foreground": "#9BDDF5" } },
    { "scope": "entity.name.tag", "settings": { "foreground": "#6FC3DF" } },
    { "scope": "support.type", "settings": { "foreground": "#9BDDF5" } },
    { "scope": "support.class", "settings": { "foreground": "#9BDDF5" } },
    { "scope": "support.function", "settings": { "foreground": "#C5D4E3" } },
    { "scope": "support.constant", "settings": { "foreground": "#FF8533" } },
    { "scope": "variable", "settings": { "foreground": "#C5D4E3" } },
    { "scope": "variable.parameter", "settings": { "foreground": "#8FA3BD" } },
    { "scope": "variable.other", "settings": { "foreground": "#C5D4E3" } },
    { "scope": "punctuation", "settings": { "foreground": "#8FA3BD" } },
    { "scope": "punctuation.definition.tag", "settings": { "foreground": "#6FC3DF" } },
    { "scope": "meta.tag", "settings": { "foreground": "#9BDDF5" } },
    { "scope": "meta.embedded", "settings": { "foreground": "#C5D4E3" } },
    { "scope": "markup.heading", "settings": { "foreground": "#6FC3DF", "fontStyle": "bold" } },
    { "scope": "markup.bold", "settings": { "fontStyle": "bold" } },
    { "scope": "markup.italic", "settings": { "fontStyle": "italic" } },
    { "scope": "markup.underline.link", "settings": { "foreground": "#FFA500" } },
    { "scope": "invalid", "settings": { "foreground": "#FF6E00" } },
    { "scope": "invalid.deprecated", "settings": { "foreground": "#FFA500" } }
  ]
}
