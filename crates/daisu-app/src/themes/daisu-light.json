{
  "name": "Daisu Light",
  "type": "light",
  "daisuLicense": "Derived from VS Code Modern Light (MIT). See https://github.com/microsoft/vscode/blob/main/LICENSE.txt",
  "colors": {
    "editor.background": "#ffffff",
    "editor.foreground": "#3b3b3b",
    "editor.selectionBackground": "#add6ff",
    "editor.lineHighlightBackground": "#f5f5f5",
    "editorCursor.foreground": "#000000",
    "editorLineNumber.foreground": "#6e7681",
    "editorLineNumber.activeForeground": "#171184",
    "editorIndentGuide.background": "#e5e5e5",
    "editorWhitespace.foreground": "#cccccc",
    "editorBracketHighlight.foreground1": "#0431fa",
    "editorBracketHighlight.foreground2": "#319331",
    "editorBracketHighlight.foreground3": "#7b3814",
    "sideBar.background": "#f8f8f8",
    "sideBar.foreground": "#3b3b3b",
    "sideBarTitle.foreground": "#3b3b3b",
    "tab.activeBackground": "#ffffff",
    "tab.inactiveBackground": "#ececec",
    "tab.activeForeground": "#3b3b3b",
    "tab.inactiveForeground": "#868686",
    "tab.border": "#e5e5e5",
    "statusBar.background": "#f8f8f8",
    "statusBar.foreground": "#3b3b3b",
    "titleBar.activeBackground": "#f8f8f8",
    "titleBar.activeForeground": "#3b3b3b",
    "panel.background": "#f8f8f8",
    "panel.border": "#e5e5e5",
    "input.background": "#ffffff",
    "input.foreground": "#3b3b3b",
    "input.border": "#cecece",
    "button.background": "#005fb8",
    "button.foreground": "#ffffff"
  },
  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#008000", "fontStyle": "italic" } },
    { "scope": "comment.line.double-slash", "settings": { "foreground": "#008000", "fontStyle": "italic" } },
    { "scope": "comment.block.documentation", "settings": { "foreground": "#008000", "fontStyle": "italic" } },
    { "scope": "string", "settings": { "foreground": "#a31515" } },
    { "scope": "string.quoted.triple", "settings": { "foreground": "#a31515" } },
    { "scope": "string.regexp", "settings": { "foreground": "#811f3f" } },
    { "scope": "constant.numeric", "settings": { "foreground": "#098658" } },
    { "scope": "constant.language", "settings": { "foreground": "#0000ff" } },
    { "scope": "constant.character.escape", "settings": { "foreground": "#ee0000" } },
    { "scope": ["keyword", "storage.type"], "settings": { "foreground": "#0000ff" } },
    { "scope": "keyword.control", "settings": { "foreground": "#af00db" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#000000" } },
    { "scope": "storage.type", "settings": { "foreground": "#0000ff" } },
    { "scope": "storage.modifier", "settings": { "foreground": "#0000ff" } },
    { "scope": "entity.name.function", "settings": { "foreground": "#795e26" } },
    { "scope": "entity.name.class", "settings": { "foreground": "#267f99" } },
    { "scope": "entity.name.type", "settings": { "foreground": "#267f99" } },
    { "scope": "entity.name.tag", "settings": { "foreground": "#800000" } },
    { "scope": "entity.other.attribute-name", "settings": { "foreground": "#e50000" } },
    { "scope": "support.function", "settings": { "foreground": "#795e26" } },
    { "scope": "support.class", "settings": { "foreground": "#267f99" } },
    { "scope": "support.type", "settings": { "foreground": "#267f99" } },
    { "scope": "variable.parameter", "settings": { "foreground": "#001080" } },
    { "scope": "variable.language", "settings": { "foreground": "#0000ff" } },
    { "scope": "variable.other", "settings": { "foreground": "#001080" } },
    { "scope": "variable", "settings": { "foreground": "#001080" } },
    { "scope": "punctuation.definition.string", "settings": { "foreground": "#a31515" } },
    { "scope": "invalid", "settings": { "foreground": "#cd3131" } },
    { "scope": "markup.heading", "settings": { "foreground": "#000080", "fontStyle": "bold" } },
    { "scope": "markup.bold", "settings": { "fontStyle": "bold" } },
    { "scope": "markup.italic", "settings": { "fontStyle": "italic" } }
  ]
}
